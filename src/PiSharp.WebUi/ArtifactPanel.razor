<section class="ps-artifact-panel">
    <header class="ps-artifact-header">
        <div>
            <p class="ps-artifact-kicker">artifact</p>
            <h4>@Artifact.ArtifactId</h4>
        </div>
        <div class="ps-artifact-meta">
            <span>v@Artifact.VersionNumber</span>
            <span>@Artifact.NormalizedContentType</span>
        </div>
    </header>

    <iframe class="ps-artifact-frame"
            title="@($"{Artifact.ArtifactId} v{Artifact.VersionNumber}")"
            sandbox="allow-scripts"
            loading="lazy"
            srcdoc="@BuildSrcDoc(Artifact)"></iframe>
</section>

@code {
    [Parameter, EditorRequired]
    public ArtifactVersion Artifact { get; set; } = default!;

    internal static string BuildSrcDoc(ArtifactVersion artifact)
    {
        ArgumentNullException.ThrowIfNull(artifact);

        var normalizedType = artifact.NormalizedContentType;
        return normalizedType switch
        {
            "html" => WrapHtmlDocument(artifact.Content, isFullDocument: LooksLikeHtmlDocument(artifact.Content)),
            "svg" => WrapSvgDocument(artifact.Content),
            "markdown" => WrapHtmlDocument(MarkdownRenderer.ToHtml(artifact.Content), isFullDocument: false),
            _ => throw new InvalidOperationException($"Unsupported artifact content type '{artifact.ContentType}'."),
        };
    }

    private static bool LooksLikeHtmlDocument(string content)
    {
        var trimmed = (content ?? string.Empty).TrimStart();
        return trimmed.StartsWith("<!doctype html", StringComparison.OrdinalIgnoreCase) ||
            trimmed.StartsWith("<html", StringComparison.OrdinalIgnoreCase);
    }

    private static string WrapHtmlDocument(string content, bool isFullDocument)
    {
        if (isFullDocument)
        {
            return content;
        }

        return $$"""
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <base target="_blank">
  <style>
    :root {
      color-scheme: light;
      font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", serif;
      background: #fffdf8;
      color: #213c43;
    }

    body {
      margin: 0;
      padding: 1.25rem;
      line-height: 1.6;
      background:
        radial-gradient(circle at top left, rgba(240, 196, 129, 0.16), transparent 38%),
        linear-gradient(180deg, #fffdf8 0%, #f8f1e8 100%);
    }

    :is(pre, code) {
      font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
    }

    img,
    svg {
      max-width: 100%;
      height: auto;
    }
  </style>
</head>
<body>
{{content}}
</body>
</html>
""";
    }

    private static string WrapSvgDocument(string content) =>
        $$"""
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    html, body {
      margin: 0;
      min-height: 100%;
      background:
        radial-gradient(circle at top, rgba(106, 162, 175, 0.16), transparent 34%),
        linear-gradient(180deg, #f6fafb 0%, #eef5f7 100%);
    }

    body {
      display: grid;
      place-items: center;
      padding: 1rem;
    }

    svg {
      max-width: 100%;
      height: auto;
    }
  </style>
</head>
<body>
{{content}}
</body>
</html>
""";
}
